<?xml version="1.0" encoding="utf-8"?>
<!--
    添加/编辑密码页面 - 分组卡片式（参考选择分类弹窗设计语言）。
    所有输入框/按钮 id 保持不变，仅重构视觉布局。
    分组：基本信息（名称+分类）/ 账号（用户名+密码）/ 附加（网址+备注）
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:colorBackground"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextColor="?android:textColorPrimary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_lg">

            <!-- ============ 分组 1：基本信息 ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginBottom="6dp"
                android:text="📌  基本信息"
                android:textColor="?android:textColorSecondary"
                android:textSize="@dimen/form_group_title_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_form_group_card"
                android:paddingHorizontal="@dimen/form_group_padding_h"
                android:paddingVertical="@dimen/form_group_padding_v">

                <!-- 应用名/网站名 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilName"
                    style="Widget.MySecret.TextInputLayout.Form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/field_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/md_divider" />

                <!-- 分类选择行：emoji + 名称 + 箭头 -->
                <LinearLayout
                    android:id="@+id/btnCategory"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/form_category_row_height"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvCategoryEmoji"
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:text="📁" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="分类"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvCategoryLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:gravity="end"
                        android:text="@string/category_not_classified"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_chevron_right"
                        android:alpha="0.4"
                        app:tint="?android:textColorSecondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============ 分组 2：账号 ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/form_group_spacing"
                android:layout_marginBottom="6dp"
                android:text="🔑  账号"
                android:textColor="?android:textColorSecondary"
                android:textSize="@dimen/form_group_title_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_form_group_card"
                android:paddingHorizontal="@dimen/form_group_padding_h"
                android:paddingVertical="@dimen/form_group_padding_v">

                <!-- 用户名/邮箱 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUsername"
                    style="Widget.MySecret.TextInputLayout.Form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/field_username">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/md_divider" />

                <!-- 密码 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="Widget.MySecret.TextInputLayout.Form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/field_password"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- 生成密码：轻量 TextButton，紧贴密码卡片下方 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerate"
                style="@style/Widget.Material3.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:text="@string/btn_generate"
                android:textColor="?attr/colorPrimary"
                app:icon="@drawable/ic_casino"
                app:iconTint="?attr/colorPrimary" />

            <!-- ============ 分组 3：附加信息 ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/form_group_spacing"
                android:layout_marginBottom="6dp"
                android:text="📎  附加信息"
                android:textColor="?android:textColorSecondary"
                android:textSize="@dimen/form_group_title_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_form_group_card"
                android:paddingHorizontal="@dimen/form_group_padding_h"
                android:paddingVertical="@dimen/form_group_padding_v">

                <!-- 网址 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUrl"
                    style="Widget.MySecret.TextInputLayout.Form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/field_url">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/md_divider" />

                <!-- 备注 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNotes"
                    style="Widget.MySecret.TextInputLayout.Form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/field_notes">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:gravity="top|start" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- 保存按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/form_group_spacing"
                android:text="@string/btn_save"
                android:textSize="16sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
