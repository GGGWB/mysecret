<?xml version="1.0" encoding="utf-8"?>
<!--
    使用说明弹窗 - 卡片式（与其他弹窗统一设计语言）。
    📖 标题 + 可滚动内容区（代码动态填充 TextView）+ 底部"知道了"按钮。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded_surface"
    android:paddingTop="22dp"
    android:paddingBottom="14dp">

    <!-- 标题：文字相对弹窗真居中，图标贴在文字左侧 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:paddingHorizontal="20dp">

        <TextView
            android:id="@+id/tvHelpTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/help_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?android:textColorPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📖"
            android:textSize="22sp"
            app:layout_constraintTop_toTopOf="@id/tvHelpTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvHelpTitle"
            app:layout_constraintEnd_toStartOf="@id/tvHelpTitle"
            android:layout_marginEnd="8dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md_divider"
        android:layout_marginBottom="4dp" />

    <!-- 可滚动内容区：代码动态添加 TextView -->
    <ScrollView
        android:id="@+id/scrollHelp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:scrollbars="vertical"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/layoutHelpContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md_divider"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- 底部按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHelpClose"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="20dp"
        android:text="@string/help_btn_close"
        android:textColor="?attr/colorPrimary"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
