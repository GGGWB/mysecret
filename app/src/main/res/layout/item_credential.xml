<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_sm"
    android:layout_marginVertical="2dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- 第一行：网站名（独占一行） -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?android:textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 第二行：用户名 + 密码（同行各占一半） + 右侧箭头 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <!-- 分类色条 -->
            <View
                android:id="@+id/categoryBar"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="6dp"
                android:background="@color/md_primary" />

            <!-- 用户名（左半边，点击复制） -->
            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/md_hint"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="start" />

            <!-- 密码（右半边，🔐 + 掩码/明文，点击切换+复制） -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="4dp">

                <!-- 🔐 图标（点击切换显示/隐藏） -->
                <ImageView
                    android:id="@+id/ivLock"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_lock"
                    android:alpha="0.5"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="切换密码可见性" />

                <TextView
                    android:id="@+id/tvPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/md_hint"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="••••••••"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <!-- 右侧箭头（垂直居中） -->
            <ImageView
                android:id="@+id/ivArrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_chevron_right"
                android:alpha="0.3"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="编辑" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
