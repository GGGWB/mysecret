<?xml version="1.0" encoding="utf-8"?>
<!--
    解锁/设置密码库界面。
    布局核心：以"密码输入框"为锚点，约束到屏幕（可见区域）垂直居中，
    Logo 与标题在它上方、确认框/警告/解锁按钮在它下方，间距保持不变。
    键盘弹出（adjustResize）时可见区域缩小为键盘上方，输入框仍在该区域中心，
    按钮与键盘保持合适间距。

    用 ConstraintLayout + Guideline 实现精确居中：
    - 一条 50% 水平参考线作为"视觉中心"
    - tilPassword 的顶部贴在该参考线上方（让输入框中心落在参考线附近）
    - 其余元素相对 tilPassword 用约束链排列，间距由 marginBottom/marginTop 控制
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fitsSystemWindows="true">

    <!-- 50% 水平参考线：屏幕垂直中心 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <!-- Logo：填满版盾牌+锁（无 adaptive icon 留白） -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_shield_lock"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="1.0" />

    <!-- 标题：约束在输入框上方 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="解锁密码库"
        android:textColor="?android:textColorPrimary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toTopOf="@id/ivLogo"
        app:layout_constraintBottom_toTopOf="@id/tilPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <!-- 密码输入框：核心锚点，垂直居中 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPassword"
        style="@style/Widget.MySecret.TextInputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:endIconMode="password_toggle"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="输入主密码"
            android:inputType="textPassword"
            android:imeOptions="actionDone"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 确认密码（仅初始设置时显示）：约束在输入框下方 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilConfirmPassword"
        style="@style/Widget.MySecret.TextInputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:endIconMode="password_toggle"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintTop_toBottomOf="@id/tilPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="再次输入主密码"
            android:inputType="textPassword"
            android:imeOptions="actionDone"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 警告信息（仅初始设置时显示）：叠放在确认框下方，
         解锁模式 gone 时由按钮直接接续输入框 -->
    <TextView
        android:id="@+id/tvWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:text="⚠️ 主密码无法找回！"
        android:textColor="@color/md_error"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintTop_toBottomOf="@id/tilConfirmPassword"
        app:layout_constraintBottom_toTopOf="@id/btnAction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Barrier：取"输入框 / 确认框 / 警告"三者的最下沿作为按钮的上界。
         解锁模式下确认框/警告 gone，Barrier 退化为输入框底部，
         按钮即以 24dp 间距排在输入框正下方。 -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrierBottomOfInputs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="tilPassword,tilConfirmPassword,tvWarning" />

    <!-- 解锁/创建按钮：约束到 Barrier 下方，与上方可见输入元素保持 18dp 间距。 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAction"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="18dp"
        android:text="解锁"
        android:textSize="16sp"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintTop_toBottomOf="@id/barrierBottomOfInputs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
