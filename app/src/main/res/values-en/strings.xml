    <!-- Help -->
    <string name="help_title">Help</string>
    <string name="help_welcome">Welcome to MySecret!</string>
    <string name="help_step1"><b>1. Add Password</b>\nTap the + button at the bottom right, fill in the website name, username, and password, select a category, and save.</string>
    <string name="help_step2"><b>2. View Password</b>\nThe main list shows username and password mask.\n• Tap username → copy username\n• Tap 🔐 icon → show/hide password\n• Tap plaintext password → copy password</string>
    <string name="help_step3"><b>3. Edit/Delete</b>\nTap the arrow on the right of an entry → enter edit page, where you can modify info or delete the record.</string>
    <string name="help_step4"><b>4. Search</b>\nThe top search box supports searching by website name, username, password, URL, and notes.</string>
    <string name="help_step5"><b>5. Categories</b>\nLong press the title → filter passwords by category.\nManage Categories → create/rename/delete categories.</string>
    <string name="help_step6"><b>6. Sort</b>\nTap the sort icon at the top right → sort by name A-Z / Z-A / modified time.</string>
    <string name="help_step7"><b>7. Backup</b>\nTap the backup icon at the top right → export encrypted file to local or sync to WebDAV/SMB server.</string>
    <string name="help_step8"><b>8. Security</b>\n• All passwords are encrypted with AES-256-GCM\n• Master password is verified with high-strength PBKDF2 hashing\n• Clipboard is cleared 30 seconds after copying username/password\n• The lock icon at the top right manually locks the app</string>
    <string name="help_tip">💡 It is recommended to back up your vault to local or remote servers regularly to prevent data loss.</string>
    <string name="help_btn_close">Got it</string>
