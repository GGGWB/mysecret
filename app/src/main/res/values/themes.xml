<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MySecret" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryVariant">@color/md_primary_dark</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_primary</item>
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnBackground">@color/md_on_background</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorError">@color/md_error</item>
        <item name="android:statusBarColor">@color/md_primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="popupMenuStyle">@style/PopupMenuOverflow</item>
    </style>

    <style name="PopupMenuOverflow" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="android:dropDownWidth">match_parent</item>
        <item name="android:overlapAnchor">false</item>
    </style>

    <style name="Widget.MySecret.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_primary</item>
        <item name="hintTextColor">@color/md_primary</item>
    </style>

    <style name="Widget.MySecret.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>
</resources>
