<?xml version="1.0" encoding="utf-8"?>
<!--
    App 图标前景：盾牌 + 锁。
    盾牌寓意"防护/安全"，中间的锁代表"加密"。
    白色盾牌 + 蓝色锁，在蓝色背景上显眼。
    108x108 viewport，图形居中在安全区（约 66dp 可见）。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 盾牌主体：加宽但不加高（宽 52，高 62，接近原始比例） -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,22
            L80,30
            L80,52
            C80,66 70,76 54,84
            C38,76 28,66 28,52
            L28,30
            Z" />

    <!-- 盾牌内层浅蓝区域（增加层次感） -->
    <path
        android:fillColor="#1554B0"
        android:fillAlpha="0.10"
        android:pathData="M54,28
            L73,34
            L73,52
            C73,62 65,71 54,77
            C43,71 35,62 35,52
            L35,34
            Z" />

    <!-- 锁的挂钩（上方U形弧） -->
    <path
        android:fillColor="#1F6FEB"
        android:pathData="M47,46
            L47,43
            C47,39 50,36 54,36
            C58,36 61,39 61,43
            L61,46
            L58,46
            L58,43
            C58,41 56,39 54,39
            C52,39 50,41 50,43
            L50,46
            Z" />

    <!-- 锁体（圆角矩形） -->
    <path
        android:fillColor="#1F6FEB"
        android:pathData="M45,46
            L63,46
            C64.1,46 65,46.9 65,48
            L65,64
            C65,65.1 64.1,66 63,66
            L45,66
            C43.9,66 43,65.1 43,64
            L43,48
            C43,46.9 43.9,46 45,46
            Z" />

    <!-- 锁孔（白色圆点） -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,52
            m-2.4,0
            a2.4,2.4 0 1,0 4.8,0
            a2.4,2.4 0 1,0 -4.8,0" />

    <!-- 锁孔下方短竖线 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M53,55
            L55,55
            L55,61
            L53,61
            Z" />
</vector>
